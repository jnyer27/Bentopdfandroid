{
  "name": "bento-pdf",
  "private": true,
  "version": "2.8.6",
  "license": "AGPL-3.0-only",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && NODE_OPTIONS='--max-old-space-size=3072' node scripts/generate-i18n-pages.mjs && node scripts/generate-sitemap.mjs && node scripts/generate-security-headers.mjs && node scripts/seo-audit.mjs",
    "seo-audit": "node scripts/seo-audit.mjs",
    "build:with-docs": "npm run build && npm run docs:build && node scripts/include-docs-in-dist.js",
    "build:gzip": "COMPRESSION_MODE=g npm run build",
    "build:brotli": "COMPRESSION_MODE=b npm run build",
    "build:original": "COMPRESSION_MODE=o npm run build",
    "build:all": "COMPRESSION_MODE=all npm run build",
    "build:production": "VITE_USE_CDN=true npm run build:with-docs",
    "preview": "vite preview",
    "obfuscate": "node scripts/build.mjs",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest watch",
    "build:docker": "vite build",
    "format": "prettier --write .",
    "release": "node scripts/release.js patch",
    "release:minor": "node scripts/release.js minor",
    "release:major": "node scripts/release.js major",
    "serve:simple": "SIMPLE_MODE=true npm run build && npm run preview -- --port 3000",
    "serve": "npm run build && npm run preview -- --port 3000",
    "package": "node scripts/package-dist.js",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:security": "eslint . --no-inline-config --rule 'no-unsanitized/method:error' --rule 'no-unsanitized/property:error' --rule 'security/detect-eval-with-expression:error'",
    "security:codeql": "codeql database create ./codeql-db --language=javascript-typescript --source-root=. --overwrite --threads=0 && codeql database analyze ./codeql-db --format=sarif-latest --output=codeql-results.sarif --threads=0 codeql/javascript-queries:codeql-suites/javascript-security-extended.qls",
    "security:codeql:quick": "codeql database analyze ./codeql-db --format=csv --output=codeql-results.csv --threads=0 codeql/javascript-queries:codeql-suites/javascript-security-extended.qls",
    "security:patterns": "node scripts/security-patterns-check.mjs",
    "security:audit": "npm audit --audit-level=high && npm run lint:security && npm run security:patterns",
    "prepare": "husky",
    "android:sync": "npm run build:docker && npx cap sync android",
    "android:apk": "npm run android:sync && cd android && ./gradlew assembleDebug",
    "android:open": "npx cap open android"
  },
  "devDependencies": {
    "@capacitor/android": "^8.4.2",
    "@capacitor/cli": "^8.4.2",
    "@eslint/js": "^10.0.1",
    "@testing-library/dom": "^10.4.1",
    "@types/blob-stream": "^0.1.33",
    "@types/html2canvas": "^1.0.0",
    "@types/pdfkit": "^0.17.6",
    "@types/sortablejs": "^1.15.8",
    "@types/utif": "^3.0.6",
    "@vitejs/plugin-basic-ssl": "^2.3.0",
    "@vitest/coverage-v8": "^4.1.10",
    "@vitest/ui": "^4.0.18",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-no-unsanitized": "^4.1.5",
    "eslint-plugin-security": "^4.0.1",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.1.0",
    "prettier": "^3.9.5",
    "typescript": "~7.0.2",
    "typescript-eslint": "^8.64.0",
    "vite": "^8.1.5",
    "vite-plugin-compression": "^0.5.1",
    "vite-plugin-handlebars": "^2.0.3",
    "vite-plugin-node-polyfills": "^0.28.0",
    "vitepress": "^1.6.4",
    "vitest": "^4.0.18",
    "vue": "^3.5.40"
  },
  "dependencies": {
    "@capacitor/browser": "^8.0.0",
    "@capacitor/core": "^8.4.2",
    "@fontsource/cedarville-cursive": "^5.3.0",
    "@fontsource/dancing-script": "^5.3.0",
    "@fontsource/dm-sans": "^5.3.0",
    "@fontsource/great-vibes": "^5.3.0",
    "@fontsource/kalam": "^5.3.0",
    "@fontsource/lato": "^5.3.0",
    "@fontsource/merriweather": "^5.3.0",
    "@kenjiuno/msgreader": "^1.28.0",
    "@matbee/libreoffice-converter": "^2.7.1",
    "@neslinesli93/qpdf-wasm": "^0.3.0",
    "@pdf-lib/fontkit": "^1.1.1",
    "@phosphor-icons/web": "^2.1.2",
    "@retejs/lit-plugin": "^2.0.8",
    "@tailwindcss/vite": "^4.3.3",
    "@types/markdown-it": "^14.1.2",
    "@types/node-forge": "^1.3.14",
    "@types/papaparse": "^5.5.2",
    "archiver": "^8.0.0",
    "blob-stream": "^0.1.3",
    "bwip-js": "^4.11.2",
    "cropperjs": "^2.1.1",
    "diff": "^9.0.0",
    "dompurify": "^3.4.12",
    "embedpdf-snippet": "file:vendor/embedpdf/embedpdf-snippet-2.9.1.tgz",
    "fast-xml-parser": "^5.10.1",
    "heic2any": "^0.0.4",
    "highlight.js": "^11.11.1",
    "html2canvas": "^1.4.1",
    "i18next": "^26.3.6",
    "i18next-browser-languagedetector": "^8.2.1",
    "i18next-http-backend": "^4.0.0",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "jszip": "^3.10.1",
    "lit": "^3.3.3",
    "lucide": "^1.25.0",
    "markdown-it": "^14.3.0",
    "markdown-it-abbr": "^2.0.0",
    "markdown-it-anchor": "^9.2.1",
    "markdown-it-deflist": "^3.0.1",
    "markdown-it-emoji": "^3.0.0",
    "markdown-it-footnote": "^4.0.0",
    "markdown-it-ins": "^4.0.0",
    "markdown-it-mark": "^4.0.0",
    "markdown-it-sub": "^2.0.0",
    "markdown-it-sup": "^2.0.0",
    "markdown-it-task-lists": "^2.1.1",
    "markdown-it-toc-done-right": "^4.2.0",
    "mermaid": "^11.16.0",
    "microdiff": "^1.5.0",
    "node-forge": "^1.4.0",
    "papaparse": "^5.5.4",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^6.1.200",
    "pdfkit": "^0.19.1",
    "pixelmatch": "^7.2.0",
    "postal-mime": "^2.7.5",
    "rete": "^2.0.6",
    "rete-area-plugin": "^2.3.2",
    "rete-connection-plugin": "^2.0.5",
    "rete-engine": "^2.1.1",
    "rete-render-utils": "^2.0.3",
    "sortablejs": "^1.15.7",
    "tailwindcss": "^4.1.14",
    "terser": "^5.49.0",
    "tesseract.js": "^7.0.0",
    "tiff": "^7.1.2",
    "utif": "^3.1.0",
    "vite-plugin-static-copy": "^4.1.1",
    "wasm-vips": "^0.0.18",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz",
    "zgapdfsigner": "^2.7.6"
  },
  "lint-staged": {
    "*.{js,ts,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,html,css}": [
      "prettier --write"
    ]
  },
  "overrides": {
    "uuid": "^14",
    "node-forge": "^1.4.0",
    "flatted": "^3.4.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "lodash-es": "^4.18.1",
    "follow-redirects": "^1.15.11",
    "esbuild": "^0.25.0"
  }
}
